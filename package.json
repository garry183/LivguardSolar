{
  "name": "livguardsolar-visual-tests",
  "version": "1.0.0",
  "description": "Playwright visual regression tests for livguardsolar.com",
  "scripts": {
    "test:visual": "playwright test tests/visual/",
    "test:update-snapshots": "playwright test tests/visual/ --update-snapshots",
    "test:desktop": "playwright test tests/visual/ --project=chromium-desktop",
    "test:mobile": "playwright test tests/visual/ --project=mobile-chrome",
    "test:headed": "playwright test tests/visual/ --headed",
    "test:debug": "playwright test tests/visual/ --debug",
    "test:report": "playwright show-report reports/html",
    "install:browsers": "playwright install --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^25.3.3",
    "typescript": "^5.7.0"
  }
}
