{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": "."
  },
  "include": ["tests/**/*.ts", "playwright.config.ts", "global-teardown.ts", "brain/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
